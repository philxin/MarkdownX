<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notion 风格</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "PingFang SC", "Microsoft YaHei";
      line-height: 1.7;
      color: #37352f;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      margin: 0;
      padding: 20px;
      min-height: 100vh;
    }

    .markdown-body {
      max-width: 100%;
      padding: 48px 56px;
      box-sizing: border-box;
      background-color: #ffffff;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }
    
    .markdown-body h1 {
      font-size: 2.5em;
      margin-top: 0;
      margin-bottom: 0.6em;
      font-weight: 700;
      color: #000000;
      letter-spacing: -0.5px;
    }

    .markdown-body h2 {
      font-size: 1.75em;
      margin-top: 2em;
      margin-bottom: 0.8em;
      font-weight: 600;
      color: #000000;
      letter-spacing: -0.3px;
    }

    .markdown-body h3 {
      font-size: 1.4em;
      margin-top: 1.5em;
      margin-bottom: 0.6em;
      font-weight: 600;
      color: #000000;
    }
    
    .markdown-body p {
      margin-top: 0;
      margin-bottom: 1em;
    }
    
    .markdown-body a {
      color: #0366d6;
      text-decoration: none;
    }
    
    .markdown-body a:hover {
      text-decoration: underline;
    }
    
    .markdown-body code {
      font-family: "SF Mono", "Fira Code", Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 0.9em;
      padding: 0.2em 0.5em;
      margin: 0 2px;
      background-color: #f1f3f5;
      border-radius: 4px;
      color: #e03e3e;
    }

    .markdown-body pre {
      font-family: "SF Mono", "Fira Code", Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 0.9em;
      line-height: 1.6;
      overflow: auto;
      padding: 20px;
      margin-top: 0;
      margin-bottom: 20px;
      background-color: #f7f6f3;
      border-radius: 8px;
      border: 1px solid #e9e8e5;
    }
    
    .markdown-body pre code {
      background-color: transparent;
      padding: 0;
    }

    /* 覆盖 highlight.js 样式以匹配主题 */
    .markdown-body pre code.hljs {
      display: block;
      overflow-x: auto;
      padding: 0;
      background: transparent;
    }
    
    .markdown-body blockquote {
      margin: 1.5em 0;
      padding: 16px 20px;
      color: #4b5563;
      background-color: #f9fafb;
      border-left: 4px solid #6366f1;
      border-radius: 0 8px 8px 0;
    }
    
    .markdown-body ul, .markdown-body ol {
      padding-left: 2em;
      margin-top: 0;
      margin-bottom: 16px;
    }
    
    .markdown-body li {
      margin-bottom: 0.25em;
    }
    
    .markdown-body table {
      border-collapse: collapse;
      width: 100%;
      margin-bottom: 16px;
    }
    
    .markdown-body table th, .markdown-body table td {
      padding: 12px 16px;
      border: 1px solid #e5e7eb;
      text-align: left;
    }

    .markdown-body table th {
      font-weight: 600;
      background-color: #f9fafb;
      color: #111827;
    }

    .markdown-body table tr:hover {
      background-color: #f9fafb;
    }
    
    .markdown-body img {
      max-width: 100%;
      box-sizing: border-box;
    }
    
    .markdown-body hr {
      height: 1px;
      padding: 0;
      margin: 24px 0;
      background-color: #e1e4e8;
      border: 0;
    }
  </style>
</head>
<body>
  <div class="markdown-body">
    <%- content %>
  </div>
</body>
</html>
