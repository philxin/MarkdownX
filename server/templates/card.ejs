<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>卡片风格</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-light.min.css">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
      line-height: 1.6;
      color: #1f2937;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      margin: 0;
      padding: 40px 20px;
      min-height: 100vh;
    }

    .markdown-body {
      max-width: 100%;
      padding: 0;
      box-sizing: border-box;
      background-color: transparent;
    }

    .card {
      background: white;
      border-radius: 16px;
      padding: 48px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
      margin-bottom: 24px;
    }

    .markdown-body h1 {
      font-size: 2.5em;
      margin-top: 0;
      margin-bottom: 0.8em;
      font-weight: 800;
      color: #111827;
      letter-spacing: -0.025em;
      line-height: 1.2;
    }

    .markdown-body h2 {
      font-size: 1.875em;
      margin-top: 2em;
      margin-bottom: 0.8em;
      font-weight: 700;
      color: #111827;
      letter-spacing: -0.025em;
      padding-bottom: 0.5em;
      border-bottom: 2px solid #e5e7eb;
    }

    .markdown-body h3 {
      font-size: 1.5em;
      margin-top: 1.5em;
      margin-bottom: 0.6em;
      font-weight: 600;
      color: #374151;
      letter-spacing: -0.025em;
    }

    .markdown-body p {
      margin-top: 0;
      margin-bottom: 1.25em;
      color: #4b5563;
      font-size: 1.05em;
    }

    .markdown-body a {
      color: #6366f1;
      text-decoration: none;
      font-weight: 500;
      border-bottom: 2px solid transparent;
      transition: border-color 0.2s;
    }

    .markdown-body a:hover {
      border-bottom-color: #6366f1;
    }

    .markdown-body code {
      font-family: "SF Mono", "Fira Code", Consolas, monospace;
      font-size: 0.9em;
      padding: 0.2em 0.5em;
      margin: 0 2px;
      background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
      border-radius: 6px;
      color: #6366f1;
      font-weight: 600;
    }

    .markdown-body pre {
      font-family: "SF Mono", "Fira Code", Consolas, monospace;
      font-size: 0.9em;
      line-height: 1.7;
      overflow: auto;
      padding: 24px;
      margin-top: 0;
      margin-bottom: 24px;
      background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
      border-radius: 12px;
      color: #e5e7eb;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .markdown-body pre code {
      background: transparent;
      padding: 0;
      color: #e5e7eb;
      font-weight: normal;
    }

    /* 覆盖 highlight.js 样式以匹配主题 */
    .markdown-body pre code.hljs {
      display: block;
      overflow-x: auto;
      padding: 0;
      background: transparent;
    }

    .markdown-body blockquote {
      margin: 1.5em 0;
      padding: 20px 24px;
      color: #6b7280;
      background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
      border-left: 4px solid #6366f1;
      border-radius: 0 12px 12px 0;
      font-style: italic;
    }

    .markdown-body ul, .markdown-body ol {
      padding-left: 1.8em;
      margin-top: 0;
      margin-bottom: 1.25em;
    }

    .markdown-body li {
      margin-bottom: 0.6em;
      color: #4b5563;
    }

    .markdown-body li::marker {
      color: #6366f1;
      font-weight: bold;
    }

    .markdown-body table {
      border-collapse: separate;
      border-spacing: 0;
      width: 100%;
      margin-bottom: 24px;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .markdown-body table th,
    .markdown-body table td {
      padding: 14px 18px;
      border-bottom: 1px solid #e5e7eb;
      text-align: left;
    }

    .markdown-body table th {
      font-weight: 600;
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
      color: #ffffff;
      text-transform: uppercase;
      font-size: 0.85em;
      letter-spacing: 0.05em;
    }

    .markdown-body table tr:last-child td {
      border-bottom: none;
    }

    .markdown-body table tbody tr:hover {
      background-color: #f9fafb;
    }

    .markdown-body img {
      max-width: 100%;
      border-radius: 12px;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .markdown-body hr {
      height: 2px;
      padding: 0;
      margin: 40px 0;
      background: linear-gradient(to right, transparent, #d1d5db, transparent);
      border: 0;
    }

    .markdown-body strong {
      color: #111827;
      font-weight: 700;
    }

    .markdown-body em {
      color: #6366f1;
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="markdown-body">
    <div class="card">
      <%- content %>
    </div>
  </div>
</body>
</html>
