<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Paper 风格</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
  <style>
    body {
      font-family: "Times New Roman", Times, serif;
      line-height: 1.6;
      color: #333333;
      background-color: #f5f5f5;
      margin: 0;
      padding: 0;
    }
    
    .markdown-body {
      max-width: 100%;
      padding: 40px;
      box-sizing: border-box;
      background-color: #ffffff;
      border-radius: 3px;
      box-shadow: 0 1px 10px rgba(0, 0, 0, 0.1);
      position: relative;
      background-image: linear-gradient(#f9f9f9 1px, transparent 1px);
      background-size: 100% 28px;
    }
    
    /* 添加纸张效果 */
    .markdown-body::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
        radial-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px);
      background-size: 20px 20px;
      background-position: 0 0, 10px 10px;
      pointer-events: none;
      z-index: 1;
    }
    
    .markdown-body * {
      position: relative;
      z-index: 2;
    }
    
    .markdown-body h1 {
      font-size: 2.25em;
      margin-top: 0;
      margin-bottom: 0.8em;
      font-weight: 600;
      color: #000000;
      text-align: center;
      border-bottom: 2px solid #000000;
      padding-bottom: 0.3em;
    }
    
    .markdown-body h2 {
      font-size: 1.5em;
      margin-top: 1.5em;
      margin-bottom: 0.5em;
      font-weight: 600;
      color: #000000;
      border-bottom: 1px solid #eaecef;
      padding-bottom: 0.3em;
    }
    
    .markdown-body h3 {
      font-size: 1.25em;
      margin-top: 1.5em;
      margin-bottom: 0.5em;
      font-weight: 600;
      color: #000000;
    }
    
    .markdown-body p {
      margin-top: 0;
      margin-bottom: 1em;
      text-align: justify;
    }
    
    .markdown-body a {
      color: #0366d6;
      text-decoration: none;
    }
    
    .markdown-body a:hover {
      text-decoration: underline;
    }
    
    .markdown-body code {
      font-family: "Courier New", Courier, monospace;
      font-size: 85%;
      padding: 0.2em 0.4em;
      margin: 0;
      background-color: rgba(27, 31, 35, 0.05);
      border-radius: 3px;
    }
    
    .markdown-body pre {
      font-family: "Courier New", Courier, monospace;
      font-size: 85%;
      line-height: 1.45;
      overflow: auto;
      padding: 16px;
      margin-top: 0;
      margin-bottom: 16px;
      background-color: #f6f8fa;
      border-radius: 3px;
      border: 1px solid #eaecef;
    }
    
    .markdown-body pre code {
      background-color: transparent;
      padding: 0;
    }

    /* 覆盖 highlight.js 样式以匹配主题 */
    .markdown-body pre code.hljs {
      display: block;
      overflow-x: auto;
      padding: 0;
      background: transparent;
    }
    
    .markdown-body blockquote {
      margin: 0;
      padding: 0 1em;
      color: #6a737d;
      border-left: 3px solid #e1e4e8;
      font-style: italic;
    }
    
    .markdown-body ul, .markdown-body ol {
      padding-left: 2em;
      margin-top: 0;
      margin-bottom: 16px;
    }
    
    .markdown-body li {
      margin-bottom: 0.25em;
    }
    
    .markdown-body table {
      border-collapse: collapse;
      width: 100%;
      margin-bottom: 16px;
    }
    
    .markdown-body table th, .markdown-body table td {
      padding: 6px 13px;
      border: 1px solid #dfe2e5;
    }
    
    .markdown-body table th {
      font-weight: 600;
      background-color: #f6f8fa;
    }
    
    .markdown-body img {
      max-width: 100%;
      box-sizing: border-box;
    }
    
    .markdown-body hr {
      height: 1px;
      padding: 0;
      margin: 24px 0;
      background-color: #e1e4e8;
      border: 0;
    }
    
    /* 添加页码效果 */
    .markdown-body::after {
      content: "1";
      position: absolute;
      bottom: 10px;
      right: 20px;
      font-size: 12px;
      color: #777;
    }
  </style>
</head>
<body>
  <div class="markdown-body">
    <%- content %>
  </div>
</body>
</html>
